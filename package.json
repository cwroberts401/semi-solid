{
  "name": "semi-solid",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build:packages": "pnpm --filter './packages/*' run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "ci:publish": "pnpm run build:packages && pnpm publish -r --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
