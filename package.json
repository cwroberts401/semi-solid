{
  "name": "semi-solid",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "semi-solid dev --brand brand-a --locale en",
    "dev:watch": "semi-solid dev --brand brand-a --locale en --no-shopify",
    "build": "semi-solid build --brand brand-a --locale en",
    "build:all": "semi-solid build-all",
    "build:brand-a": "semi-solid build --brand brand-a --locale en && semi-solid build --brand brand-a --locale fr",
    "build:brand-b": "semi-solid build --brand brand-b --locale en && semi-solid build --brand brand-b --locale de",
    "build:brand-c": "semi-solid build --brand brand-c --locale en",
    "preview": "semi-solid build --brand brand-a --locale en && shopify theme console --path ./dist/brand-a/en",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build:packages": "pnpm --filter './packages/*' run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "ci:publish": "pnpm run build:packages && pnpm publish -r --access public"
  },
  "dependencies": {
    "@semi-solid/runtime": "workspace:*",
    "@semi-solid/solid": "workspace:*",
    "solid-js": "^1.9.0",
    "solid-transition-group": "^0.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@semi-solid/compiler": "workspace:*",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-vitest": "^10.2.13",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/browser": "^3.2.4",
    "concurrently": "^8.0.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "storybook": "^10.2.13",
    "storybook-solidjs-vite": "^10.0.9",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-solid": "^2.10.0",
    "vitest": "^3.2.4"
  }
}
