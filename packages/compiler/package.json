{
  "name": "@semi-solid/compiler",
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "bin": {
    "semi-solid": "./dist/cli/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli/config": {
      "types": "./dist/cli/config.d.ts",
      "import": "./dist/cli/config.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "cp ../../LICENSE .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "citty": "^0.2.1",
    "magic-string": "^0.30.0",
    "oxc-parser": "^0.56.0"
  },
  "peerDependencies": {
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
