{
  "name": "@semi-solid/solid",
  "version": "0.1.2",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./i18n": {
      "types": "./dist/i18n.d.ts",
      "import": "./dist/i18n.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./tapWhen": {
      "types": "./dist/tapWhen.d.ts",
      "import": "./dist/tapWhen.js"
    },
    "./tapRemote": {
      "types": "./dist/tapRemote.d.ts",
      "import": "./dist/tapRemote.js"
    },
    "./tapPersonalized": {
      "types": "./dist/tapPersonalized.d.ts",
      "import": "./dist/tapPersonalized.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "cp ../../LICENSE .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@semi-solid/runtime": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
